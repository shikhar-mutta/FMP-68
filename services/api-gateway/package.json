{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "FMP-68 API Gateway — routes traffic to microservices",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "NODE_OPTIONS=--no-deprecation nest start",
