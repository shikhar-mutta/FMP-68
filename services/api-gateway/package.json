{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "FMP-68 API Gateway — routes traffic to microservices",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "NODE_OPTIONS=--no-deprecation nest start",
    "start:dev": "NODE_OPTIONS=--no-deprecation nest start --watch",
    "start:prod": "NODE_OPTIONS=--no-deprecation node dist/main",
    "test": "jest --passWithNoTests --forceExit",
    "test:cov": "jest --coverage --passWithNoTests --forceExit"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s", "!**/node_modules/**"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
