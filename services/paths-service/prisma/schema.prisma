generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  googleId        String   @unique
  email           String   @unique
  name            String
  picture         String   @default("")
  isOnline        Boolean  @default(false)
  lastSeen        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  followedPathIds String[] @db.ObjectId @default([])

  publishedPaths  Path[]   @relation("PublishedPaths")

  @@map("users")
}

model Path {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  publisherId    String   @db.ObjectId
  publisher      User     @relation("PublishedPaths", fields: [publisherId], references: [id], onDelete: Cascade)
  followerIds    String[] @db.ObjectId @default([])
  followRequests String[] @db.ObjectId @default([])
  coordinates    Json[]   @default([])
  status         String   @default("idle")
  isLive         Boolean  @default(false)

  @@map("paths")
}
